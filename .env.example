# === OBRIGATÓRIAS ===
# Chave da API OpenAI
OPENAI_API_KEY=
# Caminho pro JSON da service account do Google Calendar
GOOGLE_SERVICE_ACCOUNT_PATH=
# Token do bot do Telegram (via @BotFather)
TELEGRAM_BOT_TOKEN=

# === OPCIONAIS (já têm valor padrão) ===

# Chat ID do dono no Telegram (preenchido automaticamente na primeira mensagem)
TELEGRAM_OWNER_CHAT_ID=

# Porta do healthcheck do bot (usado pelo pipeline de deploy)
TELEGRAM_HEALTH_PORT=3002

# ID do Google Calendar (padrão: "primary")
GOOGLE_CALENDAR_ID=

# Modelo OpenAI
OPENAI_MODEL=gpt-5.4-mini

# Máximo de mensagens no histórico por conversa
MAX_HISTORY=20
